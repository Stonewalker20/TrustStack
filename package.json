{
  "name": "truststack-frontend",
  "private": true,
  "version": "0.0.2",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "verify:frontend": "cd frontend && npm run build",
    "verify:backend:unit": "cd backend && ./.venv/bin/python -m unittest tests.test_api tests.test_services -v",
    "verify:backend:integration": "docker compose up -d mongo && cd backend && ./.venv/bin/python -m unittest tests.test_integration_mongo -v",
    "verify:e2e": "playwright test",
    "verify:smoke": "playwright test --config=playwright.smoke.config.ts",
    "verify": "npm run verify:frontend && npm run verify:backend:unit && npm run verify:backend:integration && npm run verify:e2e && npm run verify:smoke"
  },
  "dependencies": {
    "@react-three/drei": "^10.1.2",
    "@react-three/fiber": "^9.1.2",
    "axios": "^1.8.4",
    "motion": "^12.12.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.176.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@types/react": "^18.3.20",
    "@types/react-dom": "^18.3.6",
    "@vitejs/plugin-react": "^4.4.1",
    "typescript": "^5.8.3",
    "vite": "^5.4.18"
  }
}
